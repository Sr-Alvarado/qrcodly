{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["DOM", "ES2022"],
		"jsx": "react-jsx",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"types": ["chrome", "vite/client"],
		"baseUrl": ".",
		"paths": {
			"@/env": ["./src/shims/env.ts"],
			"@/i18n/routing": ["./src/shims/i18n-routing.ts"],
			"@/i18n/navigation": ["./src/shims/i18n-navigation.ts"],
			"@/*": ["./../frontend/src/*"],
			"@ext/*": ["./src/*"],
			"@shared/schemas": ["./../../packages/shared/src"],
			"@shared/schemas/*": ["./../../packages/shared/src/*"]
		}
	},
	"include": ["src"]
}

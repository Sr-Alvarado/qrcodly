{
	"id": "7b62450e",
	"name": "QRcodly",
	"version": "0.2.0",
	"main": "index.html",
	"manifestVersion": 5,
	"host": {
		"app": "ID",
		"minVersion": "18.5.0"
	},
	"icons": [
		{
			"width": 48,
			"height": 48,
			"path": "icons/plugin-dark.png",
			"scale": [1, 2],
			"theme": ["darkest", "dark", "medium"],
			"species": ["pluginList"]
		},
		{
			"width": 48,
			"height": 48,
			"path": "icons/plugin-light.png",
			"scale": [1, 2],
			"theme": ["lightest", "light"],
			"species": ["pluginList"]
		}
	],
	"entrypoints": [
		{
			"type": "panel",
			"id": "qrcodly",
			"label": {
				"default": "QRcodly"
			},
			"icons": [
				{
					"width": 23,
					"height": 23,
					"path": "icons/dark.png",
					"scale": [1, 2],
					"theme": ["darkest", "dark", "medium"]
				},
				{
					"width": 23,
					"height": 23,
					"path": "icons/light.png",
					"scale": [1, 2],
					"theme": ["lightest", "light"]
				}
			],
			"minimumSize": { "width": 320, "height": 480 },
			"preferredDockedSize": { "width": 360, "height": 640 }
		}
	],
	"requiredPermissions": {
		"network": {
			"domains": ["https://qrcodly.de", "https://*.qrcodly.de"]
		},
		"localFileSystem": "plugin",
		"clipboard": "readAndWrite"
	}
}
